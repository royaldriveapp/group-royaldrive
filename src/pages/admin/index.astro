---
import { clearSessionCookie, isAuthorized } from '../../lib/adminAuth';

export const prerender = false;

if (!isAuthorized(Astro)) {
  clearSessionCookie(Astro);
  return Astro.redirect('/admin-control');
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Editor</title>
  <style is:global>
    :root {
      --bg: #050505;
      --surface: #111111;
      --surface-2: #171717;
      --border: rgba(255,255,255,0.08);
      --text: #f3f3f3;
      --muted: #9a9a9a;
      --gold: #c9a84c;
      --danger: #ff8d75;
      --success: #71d39f;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: linear-gradient(180deg, #0b0b0b 0%, #040404 100%);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
    }
    .shell { max-width: 1220px; margin: 0 auto; padding: 28px 24px 40px; }
    .topbar { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 20px; }
    h1 { margin: 0; font-size: clamp(2rem, 4vw, 2.8rem); }
    .topbar p { margin: 8px 0 0; color: var(--muted); }
    .actions { display: flex; gap: 12px; flex-wrap: wrap; }
    button, .link-btn {
      appearance: none; border: 0; border-radius: 999px; padding: 12px 18px; font: inherit; font-weight: 700; cursor: pointer; text-decoration: none; font-size: 0.95rem;
    }
    .primary { background: linear-gradient(135deg, #d6b35b, #b99032); color: #111; }
    .secondary { background: var(--surface-2); color: var(--text); border: 1px solid var(--border); }
    .status {
      margin-bottom: 20px; padding: 14px 16px; border-radius: 14px; background: var(--surface); border: 1px solid var(--border); color: var(--muted); min-height: 54px;
    }
    .status.error { color: var(--danger); border-color: rgba(255,141,117,0.25); }
    .status.success { color: var(--success); border-color: rgba(113,211,159,0.25); }
    .editor { display: grid; grid-template-columns: 240px minmax(0, 1fr); gap: 20px; align-items: start; }
    .editor-sidebar {
      position: sticky;
      top: 20px;
      border: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0)), var(--surface);
      border-radius: 16px;
      padding: 12px;
    }
    .editor-sidebar h2 {
      margin: 6px 8px 10px;
      font-size: 0.78rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .section-nav {
      display: grid;
      gap: 6px;
    }
    .section-nav button {
      border-radius: 10px;
      padding: 10px 12px;
      text-align: left;
      background: transparent;
      border: 1px solid transparent;
      color: var(--text);
      font-weight: 600;
      font-size: 0.9rem;
    }
    .section-nav button:hover {
      background: rgba(255,255,255,0.03);
      border-color: var(--border);
    }
    .editor-main {
      display: grid;
      gap: 16px;
      min-width: 0;
    }
    .card { border: 1px solid var(--border); background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0)), var(--surface); border-radius: 20px; padding: 20px; }
    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }
    .section-pill {
      font-size: 0.72rem;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 4px 10px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      white-space: nowrap;
    }
    .card > h2, .card > h3 { margin: 0 0 14px; font-size: 1.05rem; color: var(--gold); letter-spacing: 0.03em; text-transform: capitalize; }
    .grid { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
    .field, .item-block { display: grid; gap: 8px; align-content: start; }
    .item-block { padding: 14px; background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.005)), var(--surface-2); border-radius: 14px; border: 1px solid var(--border); margin-bottom: 12px; }
    label { color: var(--muted); font-size: 0.74rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }
    input, textarea {
      width: 100%; border-radius: 10px; border: 1px solid var(--border); background: #0d0d0d; color: var(--text); padding: 10px 12px; font: inherit; font-size: 0.95rem; line-height: 1.4;
    }
    input:focus, textarea:focus {
      outline: none;
      border-color: rgba(201, 168, 76, 0.6);
      box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.12);
    }
    textarea { min-height: 96px; resize: vertical; }
    .array-actions, .footer-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px; }
    .save-bar {
      position: sticky;
      bottom: 14px;
      z-index: 3;
      border: 1px solid var(--border);
      background: rgba(17, 17, 17, 0.92);
      backdrop-filter: blur(6px);
      border-radius: 14px;
      padding: 12px;
      display: flex;
      justify-content: flex-end;
    }
    .mini { background: transparent; border: 1px solid var(--border); color: var(--text); padding: 8px 12px; font-size: 0.82rem; }
    .danger { border-color: rgba(255,141,117,0.25); color: var(--danger); }
    .loading { color: var(--muted); }
    @media (max-width: 768px) {
      .shell { padding: 18px; }
      .topbar { align-items: flex-start; flex-direction: column; }
      .editor { grid-template-columns: 1fr; }
      .editor-sidebar { position: static; }
      .section-nav { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .grid { grid-template-columns: 1fr; }
      .card { padding: 16px; border-radius: 16px; }
    }
  </style>
</head>
<body>
  <div class="shell">
    <div class="topbar">
      <div>
        <h1>Content Editor</h1>
        <p>Edit site data and save changes (GitHub sync when token is configured).</p>
      </div>
      <div class="actions">
        <a class="link-btn secondary" href="/" target="_blank" rel="noopener noreferrer">View site</a>
        <form method="post" action="/api/admin-logout">
          <button class="secondary" type="submit">Log out</button>
        </form>
      </div>
    </div>

    <div id="status" class="status">Loading content…</div>
    <div id="editor" class="editor loading">Loading editor…</div>
  </div>

  <script is:inline>
    const statusEl = document.getElementById('status');
    const editorEl = document.getElementById('editor');
    let contentState = null;
    const sectionLabels = { site:'Site', navigation:'Navigation', hero:'Hero', about:'About', whyInvest:'Why Invest', faq:'FAQ', contact:'Contact', locations:'Locations', footer:'Footer' };

    function setStatus(message, tone = '') {
      statusEl.textContent = message;
      statusEl.className = `status ${tone}`.trim();
    }

    function titleize(value) {
      return value.replace(/([A-Z])/g, ' $1').replace(/[_-]/g, ' ').replace(/\s+/g, ' ').trim().replace(/^./, m => m.toUpperCase());
    }

    function isPlainObject(value) {
      return Object.prototype.toString.call(value) === '[object Object]';
    }

    function createField(label, value, onInput) {
      const wrap = document.createElement('div');
      wrap.className = 'field';
      const labelEl = document.createElement('label');
      labelEl.textContent = label;
      const input = typeof value === 'string' && (value.length > 100 || value.includes('\n'))
        ? document.createElement('textarea')
        : document.createElement('input');
      input.value = value ?? '';
      input.addEventListener('input', (event) => onInput(event.target.value));
      wrap.append(labelEl, input);
      return wrap;
    }

    function renderObjectCard(sectionKey, title, obj, onChange) {
      const card = document.createElement('section');
      card.className = 'card section-card';
      card.id = `section-${sectionKey}`;
      const head = document.createElement('div');
      head.className = 'section-head';
      const heading = document.createElement('h2');
      heading.textContent = title;
      const pill = document.createElement('span');
      pill.className = 'section-pill';
      pill.textContent = `${Object.keys(obj).length} fields`;
      head.append(heading, pill);
      const grid = document.createElement('div');
      grid.className = 'grid';

      Object.entries(obj).forEach(([key, value]) => {
        if (Array.isArray(value)) {
          grid.append(renderArrayBlock(key, value, (next) => { obj[key] = next; onChange(); }));
        } else if (isPlainObject(value)) {
          grid.append(renderNestedObject(key, value, () => onChange()));
        } else {
          grid.append(createField(titleize(key), value, (next) => { obj[key] = next; onChange(); }));
        }
      });

      card.append(head, grid);
      return card;
    }

    function renderNestedObject(title, obj, onChange) {
      const block = document.createElement('div');
      block.className = 'item-block';
      const heading = document.createElement('h3');
      heading.textContent = titleize(title);
      const grid = document.createElement('div');
      grid.className = 'grid';

      Object.entries(obj).forEach(([key, value]) => {
        if (Array.isArray(value)) {
          grid.append(renderArrayBlock(key, value, (next) => { obj[key] = next; onChange(); }));
        } else if (isPlainObject(value)) {
          grid.append(renderNestedObject(key, value, onChange));
        } else {
          grid.append(createField(titleize(key), value, (next) => { obj[key] = next; onChange(); }));
        }
      });

      block.append(heading, grid);
      return block;
    }

    function blankFromTemplate(template) {
      if (Array.isArray(template)) return [];
      if (isPlainObject(template)) return Object.fromEntries(Object.entries(template).map(([key, value]) => [key, blankFromTemplate(value)]));
      return '';
    }

    function renderArrayBlock(title, items, onChange) {
      const block = document.createElement('div');
      block.className = 'item-block';
      const heading = document.createElement('h3');
      heading.textContent = titleize(title);
      const list = document.createElement('div');

      const redraw = () => {
        list.innerHTML = '';
        items.forEach((item, index) => {
          const itemWrap = document.createElement('div');
          itemWrap.className = 'item-block';
          const itemHeading = document.createElement('h3');
          itemHeading.textContent = `${titleize(title)} ${index + 1}`;
          itemWrap.append(itemHeading);

          if (isPlainObject(item)) {
            Object.entries(item).forEach(([key, value]) => {
              if (Array.isArray(value)) {
                itemWrap.append(renderArrayBlock(key, value, () => onChange(items)));
              } else if (isPlainObject(value)) {
                itemWrap.append(renderNestedObject(key, value, () => onChange(items)));
              } else {
                itemWrap.append(createField(titleize(key), value, (next) => { item[key] = next; onChange(items); }));
              }
            });
          } else {
            itemWrap.append(createField(titleize(title), item, (next) => { items[index] = next; onChange(items); }));
          }

          const actions = document.createElement('div');
          actions.className = 'array-actions';
          const remove = document.createElement('button');
          remove.type = 'button';
          remove.className = 'mini danger';
          remove.textContent = 'Remove';
          remove.addEventListener('click', () => {
            items.splice(index, 1);
            redraw();
            onChange(items);
          });
          actions.append(remove);
          itemWrap.append(actions);
          list.append(itemWrap);
        });
      };

      redraw();

      const footerActions = document.createElement('div');
      footerActions.className = 'footer-actions';
      const add = document.createElement('button');
      add.type = 'button';
      add.className = 'mini';
      add.textContent = `Add ${titleize(title).replace(/s$/, '')}`;
      add.addEventListener('click', () => {
        const template = items[0] ?? '';
        items.push(blankFromTemplate(template));
        redraw();
        onChange(items);
      });
      footerActions.append(add);
      block.append(heading, list, footerActions);
      return block;
    }

    function renderEditor(data) {
      editorEl.classList.remove('loading');
      editorEl.innerHTML = '';

      const sidebar = document.createElement('aside');
      sidebar.className = 'editor-sidebar';
      const sidebarTitle = document.createElement('h2');
      sidebarTitle.textContent = 'Sections';
      const sectionNav = document.createElement('div');
      sectionNav.className = 'section-nav';
      sidebar.append(sidebarTitle, sectionNav);

      const main = document.createElement('div');
      main.className = 'editor-main';

      Object.entries(data).forEach(([section, value]) => {
        if (isPlainObject(value)) {
          const label = sectionLabels[section] || titleize(section);
          const sectionCard = renderObjectCard(section, label, value, () => setStatus('Unsaved changes.'));
          main.append(sectionCard);

          const navButton = document.createElement('button');
          navButton.type = 'button';
          navButton.textContent = label;
          navButton.addEventListener('click', () => {
            document.getElementById(`section-${section}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
          sectionNav.append(navButton);
        }
      });

      const saveBar = document.createElement('div');
      saveBar.className = 'save-bar';
      const save = document.createElement('button');
      save.type = 'button';
      save.className = 'primary';
      save.textContent = 'Save changes';
      save.addEventListener('click', saveContent);
      saveBar.append(save);
      main.append(saveBar);

      editorEl.append(sidebar, main);
    }

    async function saveContent() {
      setStatus('Saving changes…');
      try {
        const response = await fetch('/api/admin-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(contentState)
        });
        const payload = await response.json();
        if (!response.ok) throw new Error(payload.error || 'Save failed.');
        setStatus('Content saved successfully.', 'success');
      } catch (error) {
        setStatus(error.message || 'Unable to save content.', 'error');
      }
    }

    async function init() {
      try {
        const response = await fetch('/api/admin-content');
        const payload = await response.json();
        if (!response.ok) throw new Error(payload.error || 'Unable to load content.');
        contentState = payload;
        renderEditor(contentState);
        setStatus('Content loaded. Make your changes and save when ready.');
      } catch (error) {
        editorEl.textContent = '';
        setStatus(error.message || 'Unable to load content.', 'error');
      }
    }

    init();
  </script>
</body>
</html>
