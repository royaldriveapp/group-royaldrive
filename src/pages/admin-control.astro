---
const error = Astro.url.searchParams.get('error');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Control</title>
  <style>
    :root {
      --bg: #050505;
      --surface: #101010;
      --surface-strong: #171717;
      --border: rgba(255, 255, 255, 0.08);
      --text: #f3f3f3;
      --text-muted: #9d9d9d;
      --gold: #c9a84c;
      --danger: #ff8c75;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0; min-height: 100vh; display: grid; place-items: center; padding: 24px;
      background: radial-gradient(circle at top, rgba(201, 168, 76, 0.16), transparent 35%), linear-gradient(180deg, #090909 0%, #030303 100%);
      color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
    }
    .panel {
      width: min(100%, 440px); padding: 32px; border-radius: 24px; border: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015)), var(--surface);
      box-shadow: 0 30px 80px rgba(0,0,0,0.45);
    }
    .eyebrow { margin: 0 0 12px; color: var(--gold); font-size: 12px; font-weight: 700; letter-spacing: 0.24em; text-transform: uppercase; }
    h1 { margin: 0 0 12px; font-size: clamp(2rem, 6vw, 2.6rem); line-height: 1; letter-spacing: -0.04em; }
    p { margin: 0 0 24px; color: var(--text-muted); line-height: 1.65; }
    .error {
      margin-bottom: 16px; padding: 12px 14px; border-radius: 14px; border: 1px solid rgba(255,140,117,0.2);
      background: rgba(255,140,117,0.08); color: var(--danger); font-size: 14px;
    }
    .field { display: grid; gap: 8px; margin-bottom: 14px; }
    label { color: var(--text-muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.12em; }
    input {
      width: 100%; border-radius: 14px; border: 1px solid var(--border); background: var(--surface-strong);
      color: var(--text); padding: 14px 16px; font: inherit;
    }
    .actions { display: grid; gap: 12px; margin-top: 8px; }
    button, a {
      display: inline-flex; align-items: center; justify-content: center; width: 100%; padding: 14px 18px;
      border-radius: 999px; border: 1px solid var(--border); font: inherit; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; transition: transform 0.2s ease, border-color 0.2s ease; text-decoration: none;
    }
    button { background: linear-gradient(135deg, #d6b35b, #b99032); color: #111; border: none; cursor: pointer; }
    a { background: var(--surface-strong); color: var(--text); }
    button:hover, a:hover { transform: translateY(-1px); }
    .note { margin-top: 16px; font-size: 13px; color: var(--text-muted); }
  </style>
</head>
<body>
  <main class="panel">
    <p class="eyebrow">Royal Drive</p>
    <h1>Admin Control</h1>
    <p>Log in to update the live site content, then save changes directly back to the GitHub repo that powers the deployment.</p>

    {error === 'invalid' && <div class="error">The username or password was incorrect.</div>}
    {error === 'config' && <div class="error">Admin credentials are missing on the server.</div>}

    <form method="post" action="/api/admin-login">
      <div class="field">
        <label for="username">Username</label>
        <input id="username" name="username" type="text" autocomplete="username" required />
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" autocomplete="current-password" required />
      </div>
      <div class="actions">
        <button type="submit">Open editor</button>
      </div>
    </form>

    <div class="actions">
      <a href="/" target="_blank" rel="noopener noreferrer">View live site</a>
    </div>

    <p class="note">This admin is built into the site, so there is no extra CMS service or Netlify Identity setup to manage.</p>
  </main>
</body>
</html>
