---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import siteData from '../data/siteData.json';

import '../styles/global.css';

const { contact } = siteData;
---

<BaseLayout
  title="Royal Drive Investors | Private Investor Access"
  description="Private investor access to Royal Drive's opportunity overview, capital strategy, and consultation request form."
>
  <Header />

  <main class="investor-page">
    <section class="investor-hero" aria-label="Royal Drive investment banner">
      <img
        class="investor-hero-image"
        src="/images/investment-landscape.png"
        alt="Royal Drive investment banner"
        width="1672"
        height="941"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
      />

      <div class="investor-hero-mobile-copy">
        <p class="subtitle">Private Investor Access</p>
        <h1>Limited-Period Investment Opportunity With Royal Drive.</h1>
        <p>
          Request the investor deck, a direct callback, and a tailored conversation around your capital goals.
        </p>
        <a href="#contact" class="btn btn-primary">Request Investor Details</a>
      </div>
    </section>

    <section class="investor-form-section" id="contact">
      <div class="container investor-form-layout">
        <div class="investor-form-copy">
          <p class="subtitle">Request Access</p>
          <h2>Start The Investor Conversation.</h2>
          <p class="investor-form-lead">
            Share your details and preferred timeline. The Royal Drive team will follow up with the next steps,
            relevant material, and a direct conversation around fit.
          </p>

          <div class="investor-form-aside">
            <div class="investor-aside-card">
              <span class="investor-point-label">What You Can Request</span>
              <p>Investor deck access, a direct callback, and a tailored discussion around your capital goals.</p>
            </div>
            <div class="investor-aside-card">
              <span class="investor-point-label">Response Flow</span>
              <p>Your enquiry feeds into the same lead system already used across the main Royal Drive site.</p>
            </div>
          </div>
        </div>

        <section class="investor-form-shell" aria-labelledby="investor-form-title">
          <div class="investor-form-head">
            <p class="subtitle">Investor Enquiry</p>
            <h2 id="investor-form-title">Request Investor Details</h2>
            <p>Complete the form below and our team will contact you directly.</p>
          </div>

          <form class="investor-form" id="investor-form" data-webhook={import.meta.env.PUBLIC_N8N_WEBHOOK_URL}>
            <input type="hidden" name="source" value="investors-subsite" />

            <div class="form-field">
              <input type="text" name="name" placeholder="Full Name" required />
            </div>

            <div class="form-row">
              <div class="form-field">
                <input type="email" name="email" placeholder="Email Address" required />
              </div>
              <div class="form-field">
                <input type="tel" name="phone" placeholder="Phone Number" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <input type="text" name="city" placeholder="City / Region" />
              </div>
              <div class="form-field">
                <select name="investmentTimeline" required>
                  <option value="" disabled selected>Investment Timeline</option>
                  {contact.timelineOptions.map((option) => (
                    <option value={option.value}>{option.label}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="form-field">
              <textarea
                name="message"
                rows="5"
                placeholder="Tell us about your investment goals, capital range, or what you would like to receive."
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary investor-submit">Request Investor Details</button>
          </form>

          <p class="investor-note">
            By submitting this form, you are asking the Royal Drive investor relations team to contact you directly.
          </p>
        </section>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    const investorNavbar = document.getElementById('main-navbar');
    investorNavbar?.classList.add('navbar-investors');

    const investorForm = document.getElementById('investor-form');
    const isDesktopExperience = window.matchMedia('(min-width: 1025px)').matches;
    const hasFinePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    window.addEventListener('load', () => {
      if (typeof gsap !== 'undefined') {
        const tlInvestor = gsap.timeline();
        tlInvestor
          .from('.navbar', { y: -50, opacity: 0, duration: 1, ease: 'power3.out' })
          .from('.investor-hero', { y: 24, opacity: 0, duration: 0.95, ease: 'power3.out' }, '-=0.45')
          .from('.investor-form-copy > *', { y: 24, opacity: 0, duration: 0.75, stagger: 0.1, ease: 'power3.out' }, '-=0.4')
          .from('.investor-form-shell', { y: 36, opacity: 0, duration: 0.85, ease: 'power3.out' }, '-=0.4');

        if (isDesktopExperience && hasFinePointer) {
          document.querySelectorAll('.btn').forEach((btn) => {
            btn.addEventListener('mousemove', (event) => {
              const rect = btn.getBoundingClientRect();
              const x = event.clientX - rect.left - rect.width / 2;
              const y = event.clientY - rect.top - rect.height / 2;
              gsap.to(btn, { x: x * 0.3, y: y * 0.3, duration: 0.4, ease: 'power2.out' });
            });

            btn.addEventListener('mouseleave', () => {
              gsap.to(btn, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1, 0.3)' });
            });
          });
        }
      }

      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (event) => {
          const href = anchor.getAttribute('href');
          if (!href || href === '#') return;

          const target = document.querySelector(href);
          if (!target) return;

          event.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    });

    if (investorForm) {
      investorForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const submitButton = investorForm.querySelector('.investor-submit');
        const webhookUrl = investorForm.getAttribute('data-webhook');
        const originalText = submitButton?.textContent || 'Request Investor Details';

        if (!submitButton) return;

        if (!webhookUrl || webhookUrl.includes('your-n8n-domain')) {
          alert('n8n Webhook URL is not configured yet in .env!');
          return;
        }

        submitButton.textContent = 'Sending...';
        submitButton.disabled = true;
        submitButton.style.opacity = '0.8';

        const formData = new FormData(investorForm);
        const payload = Object.fromEntries(formData.entries());

        try {
          const response = await fetch(webhookUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json'
            },
            body: JSON.stringify(payload)
          });

          if (!response.ok) {
            throw new Error('Server returned ' + response.status);
          }

          submitButton.textContent = 'Request Sent';
          submitButton.style.background = 'linear-gradient(135deg, #2ecc71, #1abc9c)';
          submitButton.style.opacity = '1';

          window.setTimeout(() => {
            investorForm.reset();
            submitButton.textContent = originalText;
            submitButton.style.background = '';
            submitButton.disabled = false;
          }, 2800);
        } catch (error) {
          console.error('Investor webhook payload failed:', error);
          submitButton.textContent = 'Error Sending';
          submitButton.style.background = 'linear-gradient(135deg, #e74c3c, #c0392b)';
          submitButton.style.opacity = '1';

          window.setTimeout(() => {
            submitButton.textContent = originalText;
            submitButton.style.background = '';
            submitButton.disabled = false;
          }, 2800);
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .investor-page {
    background:
      radial-gradient(circle at top right, rgba(201, 168, 76, 0.1), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.015), rgba(255, 255, 255, 0)),
      var(--clr-bg);
  }

  .investor-hero {
    position: relative;
    width: 100%;
    padding-top: clamp(92px, 9vw, 128px);
    background:
      radial-gradient(circle at top center, rgba(201, 168, 76, 0.14), transparent 42%),
      linear-gradient(180deg, rgba(6, 6, 6, 0.94) 0%, rgba(6, 6, 6, 0.54) 16%, rgba(6, 6, 6, 0.12) 34%, rgba(6, 6, 6, 0) 48%);
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .investor-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(5, 5, 5, 0.48) 0%, rgba(5, 5, 5, 0.12) 16%, rgba(5, 5, 5, 0) 28%),
      linear-gradient(180deg, rgba(5, 5, 5, 0) 72%, rgba(5, 5, 5, 0.5) 88%, #050505 100%);
    pointer-events: none;
  }

  .investor-hero-image {
    display: block;
    width: 100%;
    height: auto;
    max-width: none;
    position: relative;
    z-index: 1;
  }

  .investor-hero-mobile-copy {
    display: none;
  }

  :global(.navbar.navbar-investors) {
    background:
      linear-gradient(180deg, rgba(5, 5, 5, 0.9) 0%, rgba(5, 5, 5, 0.68) 62%, rgba(5, 5, 5, 0.28) 100%);
    backdrop-filter: blur(14px) saturate(1.2);
    -webkit-backdrop-filter: blur(14px) saturate(1.2);
    border-bottom-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
  }

  :global(.navbar.navbar-investors.scrolled) {
    background-color: rgba(3, 3, 3, 0.92);
  }

  :global(.navbar.navbar-investors .logo) {
    color: rgba(255, 255, 255, 0.98);
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.18);
  }

  :global(.navbar.navbar-investors .logo .brand-accent) {
    color: rgba(255, 255, 255, 0.4);
  }

  :global(.navbar.navbar-investors .nav-links a) {
    color: rgba(255, 255, 255, 0.74);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.18);
  }

  :global(.navbar.navbar-investors .nav-links a:hover) {
    color: rgba(255, 255, 255, 0.98);
  }

  :global(.navbar.navbar-investors .nav-links a::after) {
    background: linear-gradient(90deg, var(--clr-gold), rgba(201, 168, 76, 0.1));
  }

  :global(.navbar.navbar-investors .nav-cta) {
    padding: 0.95rem 2.1rem;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--clr-gold), #b8953f);
    color: var(--clr-bg);
    border: none;
    box-shadow: 0 6px 22px rgba(201, 168, 76, 0.18);
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  :global(.navbar.navbar-investors .nav-cta:hover) {
    background: linear-gradient(135deg, var(--clr-gold-light), var(--clr-gold));
    color: var(--clr-bg);
    box-shadow: 0 10px 28px rgba(201, 168, 76, 0.24);
  }

  .investor-form-section {
    position: relative;
    padding: 5.5rem 0 7rem;
    background:
      radial-gradient(circle at top left, rgba(201, 168, 76, 0.08), transparent 24%),
      linear-gradient(180deg, #060606 0%, #030303 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .investor-form-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(340px, 520px);
    gap: 3rem;
    align-items: start;
  }

  .investor-form-copy h2 {
    max-width: 11ch;
    margin-bottom: 1rem;
  }

  .investor-form-lead {
    max-width: 560px;
    margin-bottom: 2rem;
    color: rgba(245, 245, 245, 0.76);
  }

  .investor-form-aside {
    display: grid;
    gap: 1rem;
    max-width: 560px;
  }

  .investor-aside-card {
    padding: 1.2rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.015));
  }

  .investor-point-label {
    display: inline-block;
    margin-bottom: 0.45rem;
    color: var(--clr-gold);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .investor-form-shell {
    padding: 2rem;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02)),
      rgba(7, 7, 7, 0.92);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(12px);
  }

  .investor-form-head {
    margin-bottom: 1.5rem;
  }

  .investor-form-head h2 {
    margin-bottom: 0.8rem;
  }

  .investor-form-head p {
    color: rgba(245, 245, 245, 0.65);
  }

  .investor-form {
    display: grid;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .investor-form .form-field input,
  .investor-form .form-field select,
  .investor-form .form-field textarea {
    width: 100%;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--clr-text);
    font: inherit;
  }

  .investor-form .form-field input::placeholder,
  .investor-form .form-field textarea::placeholder {
    color: rgba(245, 245, 245, 0.42);
  }

  .investor-form .form-field select {
    appearance: none;
  }

  .investor-form .form-field textarea {
    resize: vertical;
    min-height: 150px;
  }

  .investor-form .form-field input:focus,
  .investor-form .form-field select:focus,
  .investor-form .form-field textarea:focus {
    outline: none;
    border-color: rgba(201, 168, 76, 0.5);
    box-shadow: 0 0 0 4px rgba(201, 168, 76, 0.12);
  }

  .investor-submit {
    width: 100%;
  }

  .investor-note {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: rgba(245, 245, 245, 0.48);
  }

  @media (max-width: 1024px) {
    .investor-form-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .investor-hero {
      padding-top: 84px;
    }

    .investor-hero-image {
      min-height: 280px;
      object-fit: cover;
      object-position: left center;
    }

    .investor-hero-mobile-copy {
      display: block;
      position: relative;
      z-index: 2;
      padding: 1.5rem 5% 2rem;
      background: linear-gradient(180deg, rgba(5, 5, 5, 0.04) 0%, rgba(5, 5, 5, 0.8) 28%, #050505 100%);
    }

    .investor-hero-mobile-copy h1 {
      font-size: clamp(2rem, 8vw, 2.8rem);
      line-height: 1.05;
      margin-bottom: 0.9rem;
      max-width: 11ch;
    }

    .investor-hero-mobile-copy p:not(.subtitle) {
      max-width: 32ch;
      color: rgba(245, 245, 245, 0.74);
      margin-bottom: 1.25rem;
    }

    .investor-form-section {
      padding: 4.5rem 0 5rem;
    }

    .investor-form-shell {
      padding: 1.4rem;
      border-radius: 22px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

  }
</style>
