---
import siteData from '../data/siteData.json';
const { whyInvest } = siteData;
---

<section class="invest" id="invest">
  <div class="container">
    <div class="section-header center">
      <p class="subtitle">{whyInvest.subtitle}</p>
      <h2>{whyInvest.title}</h2>
    </div>

    <div class="why-invest-story">
      <p class="why-invest-paragraph">
        {whyInvest.description}
      </p>

      <div class="why-invest-highlights">
        <div class="why-invest-chip">
          <i class="fa-solid fa-shield-halved"></i>
          <span>Trust & Transparency</span>
        </div>
        <div class="why-invest-chip">
          <i class="fa-solid fa-car-side"></i>
          <span>Luxury Market Positioning</span>
        </div>
        <div class="why-invest-chip">
          <i class="fa-solid fa-chart-line"></i>
          <span>Scalable Growth Model</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .why-invest-story {
    max-width: 980px;
    margin: 0 auto;
    padding: 3rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at top right, rgba(201, 168, 76, 0.12), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0.01)),
      var(--clr-surface-light);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
  }

  .why-invest-paragraph {
    font-size: clamp(1.15rem, 2.2vw, 1.55rem);
    line-height: 1.95;
    color: rgba(245, 245, 245, 0.9);
    text-align: center;
    max-width: 840px;
    margin: 0 auto;
  }

  .why-invest-highlights {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .why-invest-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(201, 168, 76, 0.18);
    background: rgba(201, 168, 76, 0.08);
    color: var(--clr-text);
    font-size: 0.82rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .why-invest-chip i {
    color: var(--clr-gold);
  }

  @media (max-width: 768px) {
    .why-invest-story {
      padding: 1.75rem;
    }

    .why-invest-paragraph {
      text-align: left;
      line-height: 1.85;
    }

    .why-invest-highlights {
      justify-content: flex-start;
    }
  }
</style>
