---
import siteData from '../data/siteData.json';
const { whyInvest } = siteData;
---

<section class="invest" id="invest">
  <div class="container">
    <div class="section-header center">
      <p class="subtitle">{whyInvest.subtitle}</p>
      <h2>{whyInvest.title}</h2>
    </div>

    <div class="why-invest-story">
      <div class="why-invest-topline">
        <span class="why-invest-kicker">Investor Perspective</span>
        <span class="why-invest-rule"></span>
      </div>

      <div class="why-invest-copy-wrap">
        <div class="why-invest-quote">“</div>
        <p class="why-invest-paragraph">
          {whyInvest.description}
        </p>
      </div>

      <div class="why-invest-highlights">
        <div class="why-invest-chip">
          <i class="fa-solid fa-shield-halved"></i>
          <span>Trust & Transparency</span>
        </div>
        <div class="why-invest-chip">
          <i class="fa-solid fa-car-side"></i>
          <span>Luxury Market Positioning</span>
        </div>
        <div class="why-invest-chip">
          <i class="fa-solid fa-chart-line"></i>
          <span>Scalable Growth Model</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .why-invest-story {
    max-width: 980px;
    margin: 0 auto;
    padding: 3.4rem;
    border: 1px solid rgba(201, 168, 76, 0.12);
    border-radius: 30px;
    background:
      radial-gradient(circle at top right, rgba(201, 168, 76, 0.16), transparent 26%),
      radial-gradient(circle at bottom left, rgba(201, 168, 76, 0.08), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.01)),
      var(--clr-surface-light);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 30px 80px rgba(0, 0, 0, 0.25);
  }

  .why-invest-topline {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .why-invest-kicker {
    color: var(--clr-gold);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .why-invest-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(201, 168, 76, 0.35), rgba(201, 168, 76, 0.02));
  }

  .why-invest-copy-wrap {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .why-invest-paragraph {
    font-size: clamp(1.12rem, 2.1vw, 1.45rem);
    line-height: 1.92;
    color: rgba(245, 245, 245, 0.9);
    text-align: left;
    max-width: 820px;
    margin: 0;
  }

  .why-invest-quote {
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 6rem);
    line-height: 0.9;
    color: rgba(201, 168, 76, 0.28);
    transform: translateY(-0.2rem);
  }

  .why-invest-highlights {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 1rem;
    margin-top: 2.4rem;
  }

  .why-invest-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.95rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(201, 168, 76, 0.16);
    background: linear-gradient(180deg, rgba(201, 168, 76, 0.12), rgba(201, 168, 76, 0.05));
    color: var(--clr-text);
    font-size: 0.82rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .why-invest-chip i {
    color: var(--clr-gold);
  }

  @media (max-width: 768px) {
    .why-invest-story {
      padding: 1.8rem;
      border-radius: 24px;
    }

    .why-invest-topline {
      margin-bottom: 1.2rem;
    }

    .why-invest-copy-wrap {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    .why-invest-paragraph {
      line-height: 1.85;
    }

    .why-invest-quote {
      font-size: 3.2rem;
      transform: none;
    }
  }
</style>
