---
import siteData from '../data/siteData.json';
const { verticalsTimeline } = siteData;
---

<section class="verticals-section section-padding">
  <div class="container">
    <div class="verticals-shell">
      <div class="section-header center verticals-header">
        <p class="subtitle">{verticalsTimeline.subtitle}</p>
        <h2>{verticalsTimeline.title}</h2>
        <p>{verticalsTimeline.description}</p>
      </div>

      <div class="verticals-track">
        {verticalsTimeline.items.map((item, index) => (
          <article class="vertical-card">
            <div class="vertical-step">0{index + 1}</div>
            <div class="vertical-line"></div>
            <div class="vertical-content">
              <div class="vertical-icon">
                <i class={item.icon}></i>
              </div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section-padding {
    padding: var(--section-py) 0;
  }

  .verticals-section {
    position: relative;
    z-index: 10;
  }

  .verticals-shell {
    padding: 3.5rem;
    border-radius: 30px;
    border: 1px solid rgba(201, 168, 76, 0.12);
    background:
      radial-gradient(circle at top right, rgba(201, 168, 76, 0.15), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
      var(--clr-surface);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.28);
  }

  .verticals-header {
    max-width: 780px;
    margin-bottom: 3rem;
  }

  .verticals-track {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1.25rem;
    align-items: stretch;
  }

  .vertical-card {
    position: relative;
    min-height: 100%;
    padding: 1.4rem 1.2rem 1.6rem;
    border-radius: 24px;
    border: 1px solid var(--clr-border);
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)), var(--clr-surface-light);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .vertical-card:hover {
    transform: translateY(-4px);
    border-color: rgba(201, 168, 76, 0.32);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
  }

  .vertical-step {
    color: rgba(201, 168, 76, 0.9);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .vertical-line {
    width: 100%;
    height: 1px;
    margin-bottom: 1.35rem;
    background: linear-gradient(90deg, rgba(201, 168, 76, 0.55), rgba(201, 168, 76, 0.05));
  }

  .vertical-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .vertical-icon {
    width: 54px;
    height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    background: rgba(201, 168, 76, 0.1);
    color: var(--clr-gold);
    font-size: 1.15rem;
  }

  .vertical-content h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .vertical-content p {
    font-size: 0.98rem;
    line-height: 1.75;
  }

  @media (max-width: 1200px) {
    .verticals-track {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .verticals-shell {
      padding: 2rem;
      border-radius: 24px;
    }

    .verticals-track {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .vertical-card {
      padding: 1.25rem;
    }
  }
</style>
