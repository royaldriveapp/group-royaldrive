---
/**
 * Interactive Returns Calculator Component
 * Uses GSAP for smooth number rolling and magnetic hover effects.
 */
---
<section class="calculator-section section-padding">
  <div class="container">
    <div class="calculator-card glass-panel bento-box">
      <div class="calc-header">
        <h3 class="section-subtitle">INTERACTIVE PROJECTION</h3>
        <h2 class="section-title">Model Your Returns.</h2>
        <p class="section-description">Use the slider to project capital growth over a standard 36-month hold period at our target 24% net IRR.</p>
      </div>

      <div class="calc-body">
        <div class="calc-row">
          <span class="calc-label">Initial Capital</span>
          <span class="calc-amount gold-text" id="calc-input-display">$100,000</span>
        </div>
        
        <input type="range" id="calc-slider" min="50000" max="2500000" step="25000" value="100000" class="luxury-slider">

        <div class="calc-divider"></div>

        <div class="calc-row">
          <span class="calc-label">Projected 36-Month Value</span>
          <span class="calc-result" id="calc-result-display">$190,662</span>
        </div>
        
        <p class="calc-disclaimer">* Projections are illustrative and gross of performance fees. Past performance is not indicative of future results.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .section-padding {
    padding: var(--section-py) 0;
  }

  .glass-panel {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02)),
      var(--clr-surface);
    border: 1px solid var(--clr-border);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .section-subtitle {
    margin-bottom: 0.9rem;
    color: var(--clr-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .section-title {
    margin-bottom: 1rem;
  }

  .section-description {
    max-width: 38rem;
  }

  .gold-text {
    color: var(--clr-gold);
  }

  .calculator-section {
    position: relative;
    z-index: 10;
  }
  
  .calculator-card {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
  }
  
  .calc-header {
    margin-bottom: 3rem;
  }
  
  .calc-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 1.5rem;
  }
  
  .calc-label {
    color: var(--clr-text-muted);
    font-size: 1.1rem;
    font-weight: 500;
  }
  
  .calc-amount {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
  }
  
  .calc-result {
    font-family: var(--font-display);
    font-size: 3.5rem;
    color: var(--clr-text);
    line-height: 1;
  }
  
  .luxury-slider {
    -webkit-appearance: none;
    width: 100%;
    height: 8px;
    background: rgba(255, 255, 255, 0.1);
    outline: none;
    border-radius: 4px;
    margin-bottom: 3rem;
  }
  
  .luxury-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--clr-gold);
    cursor: pointer;
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.5);
    transition: transform 0.2s;
  }
  
  .luxury-slider::-webkit-slider-thumb:hover {
    transform: scale(1.2);
  }
  
  .calc-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin-bottom: 3rem;
  }
  
  .calc-disclaimer {
    color: var(--clr-text-muted);
    font-size: 0.8rem;
    margin-top: 2rem;
    text-align: right;
  }

  @media (max-width: 768px) {
    .calculator-card {
      padding: 2rem;
    }
    .calc-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .calc-amount, .calc-result {
      font-size: 2.5rem;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('calc-slider');
    const inputDisplay = document.getElementById('calc-input-display');
    const resultDisplay = document.getElementById('calc-result-display');
    
    if (!slider || !inputDisplay || !resultDisplay) return;

    // Rate: 24% IRR compounded anually over 3 years = 1.24^3 = ~1.9066
    const rate = Math.pow(1.24, 3);
    
    // Formatting currency
    const formatStr = (num) => {
      return '$' + Math.round(num).toLocaleString('en-US');
    };

    let targetInput = parseInt(slider.value, 10);
    let targetResult = targetInput * rate;
    
    const displayTarget = {
      input: targetInput,
      result: targetResult
    };

    slider.addEventListener('input', (e) => {
      targetInput = parseInt(e.target.value, 10);
      targetResult = targetInput * rate;
      
      gsap.to(displayTarget, {
        input: targetInput,
        result: targetResult,
        duration: 0.8,
        ease: 'power3.out',
        onUpdate: () => {
          inputDisplay.innerText = formatStr(displayTarget.input);
          resultDisplay.innerText = formatStr(displayTarget.result);
        }
      });
    });
  });
</script>
