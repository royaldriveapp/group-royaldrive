---
/**
 * AboutUs Component
 * "Who We Are & What We Do" section.
 * Displays a descriptive intro alongside feature cards.
 */
import siteData from '../data/siteData.json';
const { about } = siteData;
---

<section class="horizontal-section" id="about">
  <div class="watermark collection-mark">ABOUT</div>
  <div class="horizontal-container">
    <div class="h-panel intro-panel">
      <p class="subtitle">{about.subtitle}</p>
      <h2>{about.title}</h2>
      <p>{about.description}</p>
      <div class="scroll-indicator mt-4">
        <span>The Process</span>
        <div class="scroll-line"></div>
      </div>
    </div>
    
    {about.features.map((feature, i) => (
      <div class="h-panel info-card">
        <div class="info-content">
          <span>0{i+1} / Phase</span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="about-mobile container">
    <div class="about-mobile-intro">
      <p class="subtitle">{about.subtitle}</p>
      <h2>{about.title}</h2>
      <p>{about.description}</p>
    </div>

    <div class="about-mobile-grid">
      {about.features.map((feature, i) => (
        <article class="about-mobile-card">
          <span class="about-mobile-phase">0{i + 1} / Phase</span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
/* Horizontal Scroll Collection */
.horizontal-section {
    position: relative;
    overflow: hidden;
    background-color: var(--clr-bg);
}

.horizontal-container {
    display: flex;
    flex-wrap: nowrap;
    height: 100vh;
    width: fit-content;
    align-items: center;
    padding: 0 5vw;
}

.h-panel {
    height: 70vh;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
}

.intro-panel {
    width: 40vw;
    padding-right: 5vw;
}

.intro-panel h2 {
    font-size: 4rem;
}

.scroll-indicator {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--clr-gold);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.8rem;
}

.scroll-line {
    width: 50px;
    height: 1px;
    background-color: var(--clr-gold);
    position: relative;
    overflow: hidden;
}

.scroll-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background-color: #fff;
    animation: slideLine 2s infinite ease-in-out;
}

@keyframes slideLine { 0% { left: -100%; } 100% { left: 100%; } }

.info-card {
    width: 40vw;
    margin-right: 4vw;
    border-radius: 4px;
    background-color: var(--clr-surface);
    border: 1px solid var(--clr-border);
    padding: 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

.info-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background-color: var(--clr-gold);
}

.info-content span {
    color: var(--clr-gold);
    font-size: 0.9rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
}

.info-content h3 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
}

@media (max-width: 1200px) {
    .horizontal-container { width: 500vw; }
    .h-panel { width: 45vw; }
    .intro-panel { width: 60vw; }
}
@media (max-width: 768px) {
    .watermark.collection-mark,
    .horizontal-container {
        display: none;
    }

    .horizontal-section {
        padding: var(--section-py) 0;
        overflow: visible;
    }

    .about-mobile {
        display: block;
        position: relative;
        z-index: 2;
    }

    .about-mobile-intro {
        margin-bottom: 2rem;
        max-width: 100%;
        animation: aboutMobileIntroIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .about-mobile-grid {
        display: grid;
        gap: 1rem;
    }

    .about-mobile-card {
        padding: 1.75rem;
        border-radius: var(--radius-md);
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        position: relative;
        overflow: hidden;
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
        animation: aboutMobileCardIn 0.75s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .about-mobile-card:nth-child(2) { animation-delay: 0.08s; }
    .about-mobile-card:nth-child(3) { animation-delay: 0.16s; }
    .about-mobile-card:nth-child(4) { animation-delay: 0.24s; }

    .about-mobile-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, var(--clr-gold), transparent);
    }

    .about-mobile-phase {
        display: inline-block;
        margin-bottom: 0.85rem;
        color: var(--clr-gold);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .about-mobile-card h3 {
        font-size: 1.45rem;
        margin-bottom: 0.75rem;
    }

    .about-mobile-card p,
    .about-mobile-intro p {
        max-width: 100%;
    }
}

@media (min-width: 769px) {
    .about-mobile {
        display: none;
    }
}

@keyframes aboutMobileIntroIn {
    from {
        opacity: 0;
        transform: translateY(24px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes aboutMobileCardIn {
    from {
        opacity: 0;
        transform: translateY(28px) scale(0.98);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}
</style>
