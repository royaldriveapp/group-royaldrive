---
import siteData from '../data/siteData.json';
const { site } = siteData;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#030303" />

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <!-- GSAP & Lenis (must load before page scripts) -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/lenis@1.1.18/dist/lenis.min.js"></script>
</head>
<body>
  <!-- Custom Cursor -->
  <div class="cursor"></div>
  <div class="cursor-follower"></div>

  <slot />
  <script src="https://beta.leadconnectorhq.com/loader.js" data-resources-url="https://beta.leadconnectorhq.com/chat-widget/loader.js" data-widget-id="69e30ec50518618881e00b36"></script>
  <script is:inline>
    const syncLeadConnectorDialCodes = () => {
      document.querySelectorAll('.iti__selected-flag').forEach((flag) => {
        let dialCode = flag.querySelector('.rd-dial-code');
        if (!dialCode) {
          dialCode = document.createElement('span');
          dialCode.className = 'rd-dial-code';
          const arrow = flag.querySelector('.iti__arrow');
          flag.insertBefore(dialCode, arrow || null);
        }

        const title = flag.getAttribute('title') || '';
        const match = title.match(/(\+\d+)/);
        dialCode.textContent = match ? match[1] : '';
      });
    };

    const leadConnectorObserver = new MutationObserver(() => {
      syncLeadConnectorDialCodes();
    });

    window.addEventListener('load', () => {
      syncLeadConnectorDialCodes();
      leadConnectorObserver.observe(document.body, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ['title', 'class']
      });
    });
  </script>

</body>
</html>
