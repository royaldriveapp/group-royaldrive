---
import siteData from '../data/siteData.json';
const { site } = siteData;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description
} = Astro.props;
const pathname = Astro.url.pathname;
const isAdminPage = pathname.startsWith('/admin');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#030303" />

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <!-- GSAP & Lenis (must load before page scripts) -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/lenis@1.1.18/dist/lenis.min.js"></script>
</head>
<body>
  <!-- Custom Cursor -->
  {!isAdminPage && <div class="cursor"></div>}
  {!isAdminPage && <div class="cursor-follower"></div>}

  <slot />
  {!isAdminPage && (
    <>
      <div data-chat-widget data-widget-id="69e1f01468322596ac70ce56" data-location-id="s2PduY2ugBQk7J9jRp5V"></div>
      <script is:inline>
        window.addEventListener('load', () => {
          const loadWidget = () => {
            if (document.querySelector('script[data-rd-chat-widget]')) return;
            const script = document.createElement('script');
            script.src = 'https://widgets.leadconnectorhq.com/loader.js';
            script.dataset.resourcesUrl = 'https://widgets.leadconnectorhq.com/chat-widget/loader.js';
            script.dataset.widgetId = '69e1f01468322596ac70ce56';
            script.dataset.rdChatWidget = 'true';
            document.body.appendChild(script);
          };

          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(loadWidget, { timeout: 2500 });
          } else {
            window.setTimeout(loadWidget, 1200);
          }
        });
      </script>
    </>
  )}

</body>
</html>
